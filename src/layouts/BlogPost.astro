---
// src/layouts/BlogPost.astro
const { frontmatter } = Astro.props;
import Layout from './Layout.astro';
---
<Layout title={frontmatter.title} description={frontmatter.excerpt}>
  <article class="post-wrap">
    <div class="post-header">
      <a href="/saiyan/blog/" class="back-link">&larr; All Posts</a>
      <div class="post-meta">
        <span>{frontmatter.date}</span>
        <span class="sep">&middot;</span>
        <span>{frontmatter.readTime}</span>
      </div>
      <h1 class="post-title">{frontmatter.title}</h1>
      <p class="post-excerpt">{frontmatter.excerpt}</p>
      <div class="post-tags">
        {frontmatter.tags?.map((tag) => <span class="tag">{tag}</span>)}
      </div>
    </div>

    <div class="post-body">
      <slot />
    </div>

    <div class="post-cta">
      <h3>Ready to find real vulnerabilities in your APIs?</h3>
      <p>Deploy Project Saiyan in your AWS account in under 4 hours.</p>
      <a href="https://calendly.com" target="_blank" class="btn-primary">Book a Free Demo &rarr;</a>
    </div>
  </article>
</Layout>

<style>
  .post-wrap { max-width: 780px; margin: 0 auto; padding: 4rem 2rem 6rem; }
  .back-link { font-size: 0.85rem; color: var(--text2); display: inline-block; margin-bottom: 2rem; }
  .back-link:hover { color: var(--accent); }
  .post-meta { display: flex; gap: 0.5rem; font-size: 0.82rem; color: var(--text2); margin-bottom: 1.2rem; }
  .sep { color: var(--border); }
  .post-title { font-size: clamp(1.8rem, 4vw, 2.6rem); font-weight: 800; line-height: 1.15; margin-bottom: 1.2rem; }
  .post-excerpt { color: var(--text2); font-size: 1.1rem; line-height: 1.7; margin-bottom: 1.5rem; }
  .post-tags { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 3rem; padding-bottom: 3rem; border-bottom: 1px solid var(--border); }
  .tag { background: rgba(108,99,255,0.12); color: var(--accent); border: 1px solid rgba(108,99,255,0.2); padding: 3px 10px; border-radius: 100px; font-size: 0.75rem; font-weight: 600; }

  .post-body { color: var(--text); line-height: 1.8; }
  .post-body :global(h2) { font-size: 1.5rem; font-weight: 700; margin: 2.5rem 0 1rem; }
  .post-body :global(h3) { font-size: 1.2rem; font-weight: 700; margin: 2rem 0 0.75rem; color: var(--accent2); }
  .post-body :global(p) { margin-bottom: 1.3rem; color: var(--text2); font-size: 1rem; }
  .post-body :global(strong) { color: var(--text); font-weight: 600; }
  .post-body :global(ul), .post-body :global(ol) { margin: 0 0 1.3rem 1.5rem; color: var(--text2); }
  .post-body :global(li) { margin-bottom: 0.4rem; font-size: 1rem; }
  .post-body :global(code) { background: var(--bg3); color: var(--accent2); padding: 2px 6px; border-radius: 4px; font-family: var(--mono); font-size: 0.88em; }
  .post-body :global(pre) { background: var(--bg3); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem; overflow-x: auto; margin-bottom: 1.3rem; }
  .post-body :global(pre code) { background: none; padding: 0; font-size: 0.85rem; }
  .post-body :global(blockquote) { border-left: 3px solid var(--accent); margin: 1.5rem 0; padding: 0.75rem 1.5rem; background: var(--bg2); border-radius: 0 8px 8px 0; }
  .post-body :global(hr) { border: none; border-top: 1px solid var(--border); margin: 3rem 0; }
  .post-body :global(a) { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; }

  .post-cta { margin-top: 5rem; padding: 3rem; background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius); text-align: center; }
  .post-cta h3 { font-size: 1.4rem; font-weight: 700; margin-bottom: 0.75rem; }
  .post-cta p { color: var(--text2); margin-bottom: 1.5rem; }
</style>
