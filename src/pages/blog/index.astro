---
// src/pages/blog/index.astro
import Layout from '../../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;

const posts = [
  {
    slug: 'how-we-detect-idor',
    title: 'How We Detect IDOR/BOLA Without Getting Flooded With False Positives',
    date: 'April 2026',
    readTime: '7 min read',
    tags: ['IDOR', 'BOLA', 'Detection'],
    excerpt: 'IDOR is the #1 API vulnerability class according to OWASP. Most DAST tools can\'t detect it reliably. Here\'s exactly how our 5-layer approach works.',
  },
  {
    slug: 'aws-waf-correlation',
    title: 'Why WAF Correlation Changes the Game for API Security',
    date: 'March 2026',
    readTime: '5 min read',
    tags: ['WAF', 'AWS', 'Monitoring'],
    excerpt: 'Your WAF sees every attack attempt — including the ones your scanner never sent. Correlating scan findings with WAF telemetry reveals attacker infrastructure you\'d otherwise miss.',
  },
  {
    slug: 'self-hosted-vs-saas-security-tools',
    title: 'Self-Hosted vs. SaaS Security Tools: A CISO\'s Perspective',
    date: 'February 2026',
    readTime: '6 min read',
    tags: ['Architecture', 'Compliance'],
    excerpt: 'When your vulnerability scanner runs on your own infrastructure, compliance conversations change fundamentally. No DPA, no data processing addendum, no third-party risk assessment.',
  },
];
---
<Layout title="Blog — API Security Insights">
  <section class="section blog-hero">
    <div class="section-label">The Blog</div>
    <h1 class="section-title">API Security, Done Right.</h1>
    <p class="section-sub">Practical guides on detection techniques, AWS architecture, and building a security program that scales.</p>
  </section>

  <section class="section blog-grid-section">
    <div class="blog-grid">
      {posts.map((post, i) => (
        <article class={`blog-card ${i === 0 ? 'blog-card-featured' : ''}`}>
          <div class="blog-meta">
            <span class="blog-date">{post.date}</span>
            <span class="blog-sep">·</span>
            <span class="blog-read">{post.readTime}</span>
          </div>
          <h2 class="blog-title">
            <a href={`${base}blog/${post.slug}/`}>{post.title}</a>
          </h2>
          <p class="blog-excerpt">{post.excerpt}</p>
          <div class="blog-footer">
            <div class="blog-tags">
              {post.tags.map(tag => <span class="tag">{tag}</span>)}
            </div>
            <a href={`${base}blog/${post.slug}/`} class="blog-read-link">Read →</a>
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>

<style>
  .blog-hero { padding-bottom: 2rem; }
  .blog-grid { display: grid; gap: 2rem; }
  .blog-card {
    background: var(--card); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 2.5rem;
    display: flex; flex-direction: column; gap: 1rem;
    transition: border-color 0.2s;
  }
  .blog-card:hover { border-color: rgba(108,99,255,0.4); }
  .blog-card-featured {
    background: linear-gradient(135deg, rgba(108,99,255,0.07), var(--card));
    border-color: rgba(108,99,255,0.25);
  }
  .blog-meta { display: flex; align-items: center; gap: 0.5rem; }
  .blog-date, .blog-read { font-size: 0.82rem; color: var(--text2); }
  .blog-sep { color: var(--text2); }
  .blog-title { font-size: 1.25rem; font-weight: 700; line-height: 1.3; }
  .blog-title a { color: var(--text); transition: color 0.2s; }
  .blog-title a:hover { color: var(--accent); }
  .blog-excerpt { color: var(--text2); font-size: 0.95rem; line-height: 1.7; flex: 1; }
  .blog-footer { display: flex; align-items: center; justify-content: space-between; gap: 1rem; }
  .blog-tags { display: flex; gap: 6px; flex-wrap: wrap; }
  .tag { background: rgba(108,99,255,0.12); color: var(--accent); border: 1px solid rgba(108,99,255,0.2); padding: 3px 10px; border-radius: 100px; font-size: 0.75rem; font-weight: 600; }
  .blog-read-link { color: var(--accent2); font-size: 0.9rem; font-weight: 600; white-space: nowrap; }
  .blog-read-link:hover { text-decoration: underline; }
</style>
